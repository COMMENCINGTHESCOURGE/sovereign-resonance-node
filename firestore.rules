rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Pipeline status — any authenticated read, admin only write
    match /pipeline_status/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Goal status — public read for visualization
    match /goal_status/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Entity records
    match /entities/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Event logs — append only from pipeline
    match /events/{doc} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
